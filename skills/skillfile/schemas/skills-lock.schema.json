{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skills Lock",
  "description": "Tracks installed skills state with commit hashes for reproducibility",
  "type": "object",
  "patternProperties": {
    "^[a-z][a-z0-9-]*$": {
      "type": "object",
      "required": ["repo", "branch", "commit", "installed", "skills"],
      "properties": {
        "repo": {
          "type": "string",
          "pattern": "^https://.+",
          "description": "Source repository URL"
        },
        "branch": {
          "type": "string",
          "minLength": 1,
          "description": "Git branch name"
        },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$",
          "description": "Full SHA-1 commit hash"
        },
        "installed": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 installation timestamp"
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "minItems": 1,
          "description": "List of installed skill names"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "minProperties": 1
}
