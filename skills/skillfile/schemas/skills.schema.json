{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skills Configuration",
  "description": "Defines skill repositories to install. Format: name: url@branch",
  "type": "object",
  "patternProperties": {
    "^[a-z][a-z0-9-]*$": {
      "type": "string",
      "pattern": "^https://.+@[a-zA-Z0-9._-]+$",
      "description": "Repository URL with branch: https://github.com/user/repo@branch"
    }
  },
  "additionalProperties": false,
  "minProperties": 1
}
